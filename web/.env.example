# Optional. When unset, the app calls same-origin `/api` (Vite dev proxies to http://localhost:5001).
# Use a full URL when:
# - Running `vite preview` (no dev proxy): VITE_API_BASE_URL=http://localhost:5001
# - API on another host: VITE_API_BASE_URL=https://api.example.com
# For large uploads, pointing the browser at Node directly can avoid proxy timeouts:
# VITE_API_BASE_URL=http://localhost:5001

# Optional: must match ADMIN_API_KEY in backend/.env if you set it (admin Users table / ban actions).
# VITE_ADMIN_API_KEY=your-long-random-secret
