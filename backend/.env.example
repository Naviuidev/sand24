PORT=5001
CORS_ORIGIN=http://localhost:5173
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=fashion_db
DB_PORT=3306

# Customer auth (JWT + email OTP). Generate strong random values for production.
JWT_SECRET=change-me-to-a-long-random-string
OTP_PEPPER=change-me-to-a-second-random-string

# Optional: protect /api/admin/users and ban endpoints. If set, the admin UI must send the same value (see web/.env.example VITE_ADMIN_API_KEY).
# ADMIN_API_KEY=your-long-random-secret

# Password hashing (bcrypt). Default 4 keeps signup fast; use BCRYPT_ROUNDS=10+ in production if required.
# BCRYPT_ROUNDS=4

# Gmail: use an App Password (Google Account → Security → 2-Step → App passwords).
# Save as backend/.env (same folder as index.js). Spaces in the app password are OK — the server strips them.
# If SMTP is missing, production will fail OTP send; in dev the OTP is printed in the backend terminal only (not shown in the web app).
# With SMTP on, codes are emailed. Gmail can still take 30s–2m on the *receiving* side (Google’s queue) — that is not your app “waiting”.
# Faster option: use Resend (below) so handoff is via HTTP API, not Gmail SMTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password

# For port 587 use: SMTP_PORT=587 and SMTP_SECURE=false

# Pooled SMTP (default on). Reuses TLS to Gmail — much faster after the first OTP. Set SMTP_POOL=false to disable.
# SMTP_POOL=false

# Optional: skip startup SMTP verify (not recommended).
# SMTP_WARMUP=false

# Optional override for the From header (defaults to SMTP_USER)
# SMTP_FROM=noreply@example.com

# Optional — fastest OTP to Gmail in practice: https://resend.com (free tier). If set, OTPs use Resend instead of SMTP.
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Sand 24 <onboarding@resend.dev>

# --- Blog images (app) + MySQL packet size (server) — keep these lines in sync with backend/.env ---
# MAX_BLOG_UPLOAD_MB caps each file in Node; it does NOT change MySQL. If saves fail with max_allowed_packet,
# raise MySQL GLOBAL (my.cnf / my.ini [mysqld] max_allowed_packet=128M), restart MySQL, then verify:
#   SHOW GLOBAL VARIABLES LIKE 'max_allowed_packet';
# MYSQL_SESSION_MAX_PACKET must be <= that GLOBAL value (bytes). phpMyAdmin SET GLOBAL often does not persist.
MAX_BLOG_UPLOAD_MB=32
MYSQL_SESSION_MAX_PACKET=134217728

# PhonePe Payment Gateway (Standard Checkout v2 — OAuth client id + secret; no salt key)
# PHONEPE_CLIENT_ID=
# PHONEPE_CLIENT_SECRET=
# PHONEPE_CLIENT_VERSION=1
# PHONEPE_ENV=SANDBOX
# PHONEPE_PUBLISH_EVENTS=0
# FRONTEND_URL=http://localhost:5173
